# CRA/.env.example — template only for the CRA T3010 pipeline.
#
# Hackathon participants (AI For Accountability, 2026-04-29): you do NOT
# fill this in yourself. The hackathon organizers provide a pre-populated
# `CRA/.env.public` in the info pack distributed on event day. Drop it in
# place and the pipeline connects automatically.
#
# Maintainers / local-Postgres users: copy this file to `.env` (personal
# admin overrides) or `.env.public` (shared defaults) and fill in real
# values. Both files are gitignored. See SECURITY.md at the repo root.

DB_CONNECTION_STRING=postgresql://username:password@host:5432/database?sslmode=require
