{
  "name": "ai-for-accountability-part-1",
  "version": "1.0.0",
  "description": "AI For Accountability Hackathon - CRA T3010 Charity Data Pipeline (5-Year, 2020-2024)",
  "main": "scripts/01-migrate.js",
  "scripts": {
    "migrate": "node scripts/01-migrate.js",
    "seed": "node scripts/02-seed-codes.js",
    "fetch": "node scripts/03-fetch-data.js",
    "fetch:2020": "node scripts/03-fetch-data.js --year 2020",
    "fetch:2021": "node scripts/03-fetch-data.js --year 2021",
    "fetch:2022": "node scripts/03-fetch-data.js --year 2022",
    "fetch:2023": "node scripts/03-fetch-data.js --year 2023",
    "fetch:2024": "node scripts/03-fetch-data.js --year 2024",
    "import": "node scripts/04-import-data.js",
    "import:2020": "node scripts/04-import-data.js --year 2020",
    "import:2021": "node scripts/04-import-data.js --year 2021",
    "import:2022": "node scripts/04-import-data.js --year 2022",
    "import:2023": "node scripts/04-import-data.js --year 2023",
    "import:2024": "node scripts/04-import-data.js --year 2024",
    "verify": "node scripts/05-verify.js",
    "analyze:loops": "node scripts/advanced/01-detect-all-loops.js",
    "analyze:score": "node scripts/advanced/02-score-universe.js",
    "analyze:scc": "node scripts/advanced/03-scc-decomposition.js",
    "analyze:matrix": "node scripts/advanced/04-matrix-power-census.js",
    "analyze:partitioned": "node scripts/advanced/05-partitioned-cycles.js",
    "analyze:johnson": "node scripts/advanced/06-johnson-cycles.js --max-hops 6",
    "analyze:financial": "node scripts/advanced/07-loop-financial-analysis.js",
    "analyze:all": "npm run analyze:loops && npm run analyze:scc && npm run analyze:partitioned && npm run analyze:johnson && npm run analyze:matrix && npm run analyze:financial && npm run analyze:score",
    "analyze:full": "npm run drop:loops -- --yes && npm run analyze:all",
    "drop:loops": "node scripts/drop-loop-tables.js",
    "data-quality": "npm run data-quality:donees && npm run data-quality:arithmetic && npm run data-quality:backfill",
    "data-quality:donees": "node scripts/data-quality/01-donee-bn-name-mismatches.js",
    "data-quality:arithmetic": "node scripts/data-quality/02-t3010-arithmetic-impossibilities.js",
    "data-quality:backfill": "node scripts/data-quality/03-identification-backfill-check.js",
    "lookup": "node scripts/advanced/lookup-charity.js",
    "risk": "node scripts/advanced/risk-report.js",
    "download": "node scripts/download-data.js",
    "readonly:create": "node scripts/create-readonly-user.js",
    "readonly:revoke": "node scripts/revoke-readonly-user.js",
    "drop": "node scripts/drop-tables.js",
    "clear-cache": "node scripts/clear-cache.js",
    "setup": "npm run migrate && npm run seed && npm run fetch && npm run import && npm run verify",
    "reset": "npm run drop && npm run setup",
    "test": "node --test tests/**/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js"
  },
  "keywords": [
    "cra",
    "t3010",
    "charity",
    "open-data",
    "hackathon",
    "accountability"
  ],
  "author": "AI For Accountability Hackathon Team",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "pg": "^8.11.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
